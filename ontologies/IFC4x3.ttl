        [ sh:datatype xsd:string ;
            sh:name "Role" ;
            sh:path ifc:Role ],
        [ sh:datatype xsd:string ;
            sh:name "Description" ;
            sh:path ifc:Description ] ;
    sh:targetClass ifc:IfcActorRole .

