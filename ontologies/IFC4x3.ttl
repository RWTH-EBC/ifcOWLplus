ifc:IfcActionRequestShape a sh:NodeShape ;
    rdfs:label "Shape for IfcActionRequest" ;
    sh:node ifc:IfcControlShape ;
    sh:property [ sh:datatype xsd:string ;
            sh:name "PredefinedType" ;
            sh:path ifc:PredefinedType ],
        [ sh:datatype xsd:string ;
            sh:name "Status" ;
            sh:path ifc:Status ],
        [ sh:datatype xsd:string ;
            sh:name "LongDescription" ;
            sh:path ifc:LongDescription ] ;
    sh:targetClass ifc:IfcActionRequest .

ifc:IfcActorRoleShape a sh:NodeShape ;
